{
  "name": "fleurstales-storefront",
  "version": "3.0.50",
  "scripts": {
    "clean": "rimraf dist coverage \"*.tsbuildinfo\"",
    "dev": "node scripts/dev-local.mjs",
    "build": "node scripts/build.mjs --production",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run check:architecture && npm test && npm run test:backend && npm run build",
    "test": "vitest run",
    "test:workflows": "vitest run src/workflows",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:isolated": "node scripts/test-isolated.mjs",
    "dev:local": "node scripts/dev-local.mjs",
    "backend:start": "node backend/server.mjs",
    "db:migrate": "node backend/scripts/migrate.mjs",
    "db:seed": "node backend/scripts/seed.mjs",
    "db:reset": "node backend/scripts/reset.mjs",
    "db:backup": "node backend/scripts/backup.mjs",
    "test:backend": "node --test backend/tests/*.node.mjs",
    "dev:frontend": "node scripts/build.mjs",
    "check:architecture": "node scripts/check-architecture.mjs"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.2.3",
    "@radix-ui/react-dialog": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.12",
    "@radix-ui/react-popover": "^1.1.11",
    "@radix-ui/react-select": "^2.2.2",
    "@radix-ui/react-slider": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.2.2",
    "@radix-ui/react-tabs": "^1.1.9",
    "@radix-ui/react-toast": "^1.2.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.503.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-router": "^7.5.3",
    "recharts": "^2.15.3",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.21",
    "esbuild": "0.25.4",
    "esbuild-style-plugin": "^1.6.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
